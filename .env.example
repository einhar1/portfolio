# GitHub portfolio sync
# Only shows manually pinned repositories. If no repos are pinned, displays nothing.
GITHUB_USERNAME=einhar1

# Manually pin repositories to display on your portfolio.
# Comma-separated repo names. Can be:
# - Simple name: "reponame" (searches all known owners)
# - Full path: "owner/reponame"
# Examples: armada-ths/armada.nu,medieteknik-kth/medieteknik.com,armada-ths/ArmadaCMS,einhar1/driVR,einhar1/WikiQuest,einhar1/ordbok
GITHUB_PINNED_REPOS=

# Include private repositories you have access to (requires a token with private-repo access).
# Private repos are shown as non-clickable cards and do not expose repo URLs.
GITHUB_INCLUDE_PRIVATE_REPOS=false

# Number of topic tags to show per repository card.
GITHUB_MAX_TOPICS_PER_REPO=3

# Optional, but recommended to avoid rate limits.
# Create a GitHub token with public_repo/read-only scope and place it below.
GITHUB_TOKEN=replace_with_github_token

# Optional: multiple fine-grained tokens keyed by owner (personal/org).
# Format: owner=token;other-owner=token
# Example: einhar1=github_pat_personal;armada-ths=github_pat_org
GITHUB_OWNER_TOKENS=
